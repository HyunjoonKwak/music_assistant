# =============================================================================
# Music Assistant + Home Assistant 환경 설정
# 사용법:  cp .env.example .env   후 값을 본인 NAS 환경에 맞게 수정
# =============================================================================

# 컨테이너 설정/DB가 저장될 NAS 경로 (영구 보관, 백업 권장)
# 이 프로젝트의 운영 폴더 그대로 사용
DATA_DIR=/volume1/code_work/music_assist

# NAS에 저장된 음악 라이브러리 폴더 (읽기 전용 마운트)
# Synology 예시: /volume1/music
MUSIC_DIR=/volume1/music

# 시간대
TZ=Asia/Seoul

# 로그 레벨: debug | info | warning | error
LOG_LEVEL=info
